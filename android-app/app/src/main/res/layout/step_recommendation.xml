<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖 AI Recommendation"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvRecommendSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Based on your field, market and buyer demand"
                android:textSize="13sp"
                android:textColor="@color/text_soft"
                android:layout_marginBottom="20dp"/>

            <!-- Loading state -->
            <LinearLayout
                android:id="@+id/loadingState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="40dp">
                <ProgressBar
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:indeterminateTint="@color/forest_green"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analysing market data..."
                    android:textSize="14sp"
                    android:textColor="@color/text_soft"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

            <!-- Top 3 recommendations -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecommendations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"/>

            <!-- Own choice option -->
            <LinearLayout
                android:id="@+id/cardOwnChoice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:padding="16dp"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Want to grow something else?"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etOwnCrop"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Enter crop name"
                    android:background="@drawable/input_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="textCapWords"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:id="@+id/btnConfirmOwnCrop"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:background="@drawable/bg_logout">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Use My Own Choice"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/emergency_red"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
