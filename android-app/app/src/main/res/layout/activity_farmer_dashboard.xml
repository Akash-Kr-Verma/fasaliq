<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1EFE8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Welcome, Farmer"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2C2C2A"/>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Logout"
                android:textSize="12sp"
                android:backgroundTint="#E24B4A"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Get Crop Recommendation"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2C2C2A"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etFieldSize"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Field size (acres)"
            android:inputType="numberDecimal"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etSoilType"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Soil type (loamy / clay / sandy / black)"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etIrrigation"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Irrigation (borewell / canal / rainfed)"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etLastCrop"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Last crop grown (optional)"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etSeason"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Season (kharif / rabi / annual)"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnGetRecommendation"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Get My Crop Recommendation"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0F6E56"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#2C2C2A"
            android:background="@drawable/input_bg"
            android:padding="16dp"
            android:visibility="gone"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Report a Problem"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2C2C2A"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etAnomalyType"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Problem type (over_nitrogen / pest_attack / drought_stress)"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnGetRecovery"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Get Recovery Plan"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#854F0B"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvRecovery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#2C2C2A"
            android:background="@drawable/input_bg"
            android:padding="16dp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>