<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_rounded"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:elevation="2dp">

    <!-- Rank badge + crop name -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/tvRank"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="#1"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@color/forest_green"
            android:gravity="center"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvCropName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crop Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"/>
            <TextView
                android:id="@+id/tvSeason"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Season"
                android:textSize="12sp"
                android:textColor="@color/text_soft"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">
            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/forest_green"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="score"
                android:textSize="10sp"
                android:textColor="@color/text_soft"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Income estimate -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/status_growing"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💰 Est. Income: " android:textSize="13sp" android:textColor="@color/status_growing_text" android:textStyle="bold"/>
        <TextView android:id="@+id/tvIncome" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹0" android:textSize="13sp" android:textColor="@color/status_growing_text" android:textStyle="bold"/>
        <TextView android:id="@+id/tvMSP" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textSize="11sp" android:textColor="@color/status_growing_text" android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Reasons -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Why this crop?"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:layout_marginBottom="6dp"/>

    <LinearLayout
        android:id="@+id/llReasons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="12dp"/>

    <!-- Select button -->
    <LinearLayout
        android:id="@+id/btnSelectCrop"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center"
        android:background="@color/forest_green">
        <TextView
            android:id="@+id/tvSelectLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌱 Plant This Crop"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>
