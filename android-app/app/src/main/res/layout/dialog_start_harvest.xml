<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_card_rounded">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌾 Start New Harvest"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:layout_marginBottom="20dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Field Name" android:textSize="12sp" android:textColor="@color/text_soft" android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etFieldName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="e.g. North Acre, Home Field"
        android:background="@drawable/input_bg"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:inputType="textCapWords"
        android:layout_marginBottom="14dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Crop Name" android:textSize="12sp" android:textColor="@color/text_soft" android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etCropName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="e.g. Wheat, Chickpea, Onion"
        android:background="@drawable/input_bg"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:inputType="textCapWords"
        android:layout_marginBottom="14dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Season" android:textSize="12sp" android:textColor="@color/text_soft" android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etSeason"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="kharif / rabi / annual"
        android:background="@drawable/input_bg"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:layout_marginBottom="14dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Field Size (acres)" android:textSize="12sp" android:textColor="@color/text_soft" android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etFieldSize"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="e.g. 2.5"
        android:background="@drawable/input_bg"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:inputType="numberDecimal"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/btnCancelHarvest"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:gravity="center"
            android:background="@drawable/bg_logout"
            android:layout_marginEnd="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cancel" android:textSize="14sp" android:textColor="@color/emergency_red" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnConfirmHarvest"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:gravity="center"
            android:background="@color/forest_green">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Start 🌱" android:textSize="14sp" android:textColor="#FFFFFF" android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
