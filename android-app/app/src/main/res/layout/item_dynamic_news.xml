<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card_rounded"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="10dp">
    <View android:layout_width="64dp" android:layout_height="64dp" android:background="@drawable/bg_news_image" android:layout_marginEnd="12dp"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvNewsTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="News Title" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/text_dark"/>
        <TextView android:id="@+id/tvNewsType" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="News Type" android:textSize="11sp" android:textColor="@color/text_soft" android:layout_marginTop="4dp"/>
    </LinearLayout>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="20sp" android:textColor="@color/text_soft"/>
</LinearLayout>
