<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/forest_green">
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#FFFFFF"
            android:layout_marginEnd="12dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New Harvest"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Step indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/step1Indicator"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="1"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@color/forest_green"
            android:gravity="center"/>

        <View
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_weight="1"
            android:background="@color/divider"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <TextView
            android:id="@+id/step2Indicator"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="2"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_soft"
            android:background="@color/divider"
            android:gravity="center"/>

        <View
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_weight="1"
            android:background="@color/divider"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <TextView
            android:id="@+id/step3Indicator"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="3"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_soft"
            android:background="@color/divider"
            android:gravity="center"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:id="@+id/tvStepLabel"
            android:text="Field Details"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/forest_green"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <!-- ViewPager for steps -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/stepPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Bottom button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/surface_white"
        android:elevation="4dp">

        <LinearLayout
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:gravity="center"
            android:background="@drawable/bg_card_rounded"
            android:layout_marginEnd="8dp"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/forest_green"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:gravity="center"
            android:background="@color/forest_green">
            <TextView
                android:id="@+id/tvNextLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next →"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
