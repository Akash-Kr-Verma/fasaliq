<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Newsletter" android:textSize="26sp" android:textStyle="bold" android:textColor="@color/forest_green"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stay updated, stay ahead" android:textSize="13sp" android:textColor="@color/text_soft"/>
        </LinearLayout>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_dialog_map" android:tint="@color/forest_green" android:layout_marginEnd="4dp"/>
            <TextView android:id="@+id/tvLocation" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pune, Maharashtra" android:textSize="12sp" android:textColor="@color/forest_green" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/llEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No updates available"
            android:textSize="18sp"
            android:textColor="@color/text_mid"/>
    </LinearLayout>

    <ScrollView
        android:id="@+id/svContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Weather -->
            <LinearLayout
                android:id="@+id/llWeatherContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Weather Forecast" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/text_dark"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Current Location" android:textSize="12sp" android:textColor="@color/text_soft"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_weather_card" android:padding="16dp" android:gravity="center" android:layout_marginBottom="16dp">
                    <TextView android:id="@+id/tvWeatherIcon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="☀️" android:textSize="48sp"/>
                    <TextView android:id="@+id/tvWeatherTemp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--°C" android:textSize="24sp" android:textStyle="bold" android:textColor="@color/text_dark" android:layout_marginTop="8dp"/>
                    <TextView android:id="@+id/tvWeatherCondition" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Condition" android:textSize="14sp" android:textColor="@color/text_soft"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Mandi Prices -->
            <LinearLayout
                android:id="@+id/llMandiContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Mandi Prices" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/text_dark"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Live" android:textSize="12sp" android:textColor="@color/forest_green" android:textStyle="bold"/>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvMandi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:clipToPadding="false"/>
            </LinearLayout>

            <!-- News -->
            <LinearLayout
                android:id="@+id/llNewsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Latest News &amp; Updates" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/text_dark"/>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvNews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="100dp"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
